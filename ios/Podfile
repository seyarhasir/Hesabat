# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# Third-party pod warnings (especially SQLCipher / MLKit on newer Xcode)
# should not break app builds.
inhibit_all_warnings!

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Use static frameworks to keep Swift pods (sqlcipher_flutter_libs) working
  # while avoiding dynamic framework/header verification issues.
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.generated_projects.each do |project|
    project.targets.each do |target|
      target.build_configurations.each do |config|
        # 1. Force a consistent deployment target
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        
        # 2. Kill the Module Verifier (Nuclear Option)
        config.build_settings['ENABLE_MODULE_VERIFIER'] = 'NO'
        config.build_settings['MODULE_VERIFIER_SUPPORTED_LANGUAGES'] = ''
        config.build_settings['MODULE_VERIFIER_SUPPORTED_LANGUAGE_VARIANTS'] = ''
        
        # 3. Disable header & quote warnings that block the build
        config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        
        # 4. Critical for Flutter framework visibility
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
        config.build_settings['FRAMEWORK_SEARCH_PATHS'] << '"${PODS_ROOT}/../.symlinks/flutter/ios"'
        config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
        config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/../.symlinks/flutter/ios/Flutter.framework/Headers"'

        # 5. Sandbox fix for Xcode 15/16
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

        # 6. Specific Pod Fixes
        if target.name == 'SQLCipher'
          config.build_settings['OTHER_CFLAGS'] = '$(inherited) -w'
        end
        if target.name.start_with?('MLKit') || target.name == 'GoogleMLKit' || target.name == 'MLImage'
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
        end
      end
    end
  end

  # Apply flutter-specific settings
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end
end
